<?xml version="1.0" encoding="utf-8"?>
<!--
   Main dashboard for the Android port of Eyes On The Power.

   This layout is a one-to-one match for the data the Raspberry Pi
   actually sends: a single global min / avg / max temperature plus an
   optional 160x120 thermal image.  No 3-phase breakdown - the firmware
   doesn't compute that.
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ============== Header: logo + project / team ============== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="140dp"
                android:layout_height="80dp"
                android:src="@drawable/dynamic_ratings_logo"
                android:scaleType="fitCenter"
                android:contentDescription="@string/app_name" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/title_main"
                    android:textColor="@color/accent"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/title_sub"
                    android:textColor="@color/text"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/team_line"
                    android:textColor="@color/text_dim"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:layout_marginTop="10dp"
            android:background="@color/border" />

        <!-- ============== Toolbar: source + thresholds ============== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/source_label"
                android:textColor="@color/text"
                android:textSize="13sp"
                android:layout_marginEnd="10dp" />

            <RadioGroup
                android:id="@+id/source_group"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/source_sim"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/source_sim"
                    android:textColor="@color/text"
                    android:checked="true"
                    android:layout_marginEnd="14dp" />

                <RadioButton
                    android:id="@+id/source_bt"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/source_bt_off"
                    android:textColor="@color/text"
                    android:enabled="false"
                    android:layout_marginEnd="14dp" />
            </RadioGroup>

            <Button
                android:id="@+id/btn_connect"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/connect"
                android:layout_marginStart="8dp" />

            <Button
                android:id="@+id/btn_refresh"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/refresh"
                android:layout_marginStart="6dp" />

            <CheckBox
                android:id="@+id/chk_image"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/request_image"
                android:textColor="@color/text"
                android:checked="true"
                android:layout_marginStart="14dp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/warn_label"
                android:textColor="@color/text"
                android:layout_marginEnd="4dp" />
            <EditText
                android:id="@+id/edit_warn"
                android:layout_width="64dp"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:text="140"
                android:layout_marginEnd="10dp"
                android:autofillHints="" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/crit_label"
                android:textColor="@color/text"
                android:layout_marginEnd="4dp" />
            <EditText
                android:id="@+id/edit_crit"
                android:layout_width="64dp"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:text="176"
                android:layout_marginEnd="6dp"
                android:autofillHints="" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/deg_f"
                android:textColor="@color/text_dim" />
        </LinearLayout>

        <!-- ============== Body: thermal view + right column ============== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal"
            android:baselineAligned="false">

            <!-- Thermal image card -->
            <LinearLayout
                style="@style/CardPanel"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="3"
                android:layout_marginEnd="10dp"
                android:orientation="vertical">

                <TextView
                    style="@style/CardTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/card_thermal" />

                <com.marquette.eyesonthepower.ThermalView
                    android:id="@+id/thermal_view"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:layout_marginTop="8dp"
                    android:minHeight="320dp"
                    android:background="@drawable/bg_thermal" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/lbl_fps"
                        style="@style/StatLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="FPS: --" />

                    <TextView
                        android:id="@+id/lbl_image_state"
                        style="@style/StatLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/image_on" />
                </LinearLayout>
            </LinearLayout>

            <!-- Right column -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:orientation="vertical">

                <!-- Status badge card -->
                <LinearLayout
                    style="@style/CardPanel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        style="@style/CardTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/card_status" />

                    <TextView
                        android:id="@+id/status_badge"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:padding="14dp"
                        android:gravity="center"
                        android:background="@drawable/bg_status_offline"
                        android:text="@string/status_offline"
                        android:textColor="@color/white"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/status_detail"
                        style="@style/StatLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="@string/not_connected_detail" />
                </LinearLayout>

                <!-- Temperatures card (single row of 4 numbers) -->
                <LinearLayout
                    style="@style/CardPanel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="vertical">

                    <TextView
                        style="@style/CardTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/card_temps" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center_horizontal">
                            <TextView style="@style/StatLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/lbl_min" />
                            <TextView android:id="@+id/val_min"
                                style="@style/StatBig"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/placeholder" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center_horizontal">
                            <TextView style="@style/StatLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/lbl_avg" />
                            <TextView android:id="@+id/val_avg"
                                style="@style/StatBig"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/placeholder" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center_horizontal">
                            <TextView style="@style/StatLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/lbl_max" />
                            <TextView android:id="@+id/val_max"
                                style="@style/StatBig"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/placeholder" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center_horizontal">
                            <TextView style="@style/StatLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/lbl_peak" />
                            <TextView android:id="@+id/val_peak"
                                style="@style/StatBig"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/placeholder" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- Trend card -->
                <LinearLayout
                    style="@style/CardPanel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="vertical">

                    <TextView
                        style="@style/CardTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/card_trend" />

                    <com.marquette.eyesonthepower.TrendView
                        android:id="@+id/trend_view"
                        android:layout_width="match_parent"
                        android:layout_height="160dp"
                        android:layout_marginTop="6dp" />
                </LinearLayout>

                <!-- Event log card -->
                <LinearLayout
                    style="@style/CardPanel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="vertical">

                    <TextView
                        style="@style/CardTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/card_log" />

                    <ScrollView
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:layout_marginTop="6dp"
                        android:background="@color/panel_alt">

                        <TextView
                            android:id="@+id/event_log"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="6dp"
                            android:fontFamily="monospace"
                            android:textSize="11sp"
                            android:textColor="@color/text" />
                    </ScrollView>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Footer -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/footer"
            android:textColor="@color/text_dim"
            android:textSize="11sp" />
    </LinearLayout>
</ScrollView>
